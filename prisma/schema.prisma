// Habit Tracker - Prisma Schema
// Science-based habit tracking application

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // New profile fields
  bio            String?   @db.Text
  avatarUrl      String?
  timezone       String    @default("Europe/Prague")
  lastLoginAt    DateTime?
  lastActivityAt DateTime?

  // Relations
  habits         Habit[]
  habitLogs      HabitLog[]
  identities     Identity[]
  thoughtRecords ThoughtRecord[]
  weeklyReviews  WeeklyReview[]
  preferences    UserPreferences?
  sessions       UserSession[]
  auditLogs      AuditLog[]

  @@map("users")
}

// ============================================
// HABITS
// ============================================

model Habit {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  description String?
  color       String   @default("#3B82F6") // Tailwind blue-500
  icon        String   @default("target")   // Lucide icon name

  frequency   String   @default("daily")    // daily, weekly, custom
  goal        Int      @default(1)          // times per day/week

  startDate   DateTime @default(now())
  isActive    Boolean  @default(true)

  // Implementation Intention (IF-THEN)
  // "When [trigger], I will [action], in [context]"
  trigger     String?  // When: "After I drink coffee"
  action      String?  // I will: "drink water"
  context     String?  // In: "in the kitchen"

  // Science-based features
  daysSinceStart  Int     @default(0)      // For neuroplasticity tracking
  stackedAfter    String? // Habit stacking: ID of habit to do this after
  replacesHabit   String? // Replacement behavior: old habit being replaced

  // Identity linking
  identityId      String?
  identity        Identity? @relation(fields: [identityId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  logs              HabitLog[]
  woopPlans         WoopPlan[]
  thoughtRecords    ThoughtRecord[]
  extinctionBursts  ExtinctionBurstEvent[]

  @@index([userId])
  @@index([userId, isActive])
  @@index([userId, isActive, createdAt])  // Composite index for main habits query with sorting
  @@index([identityId])
  @@map("habits")
}

// ============================================
// HABIT LOGS (Check-ins)
// ============================================

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  date      DateTime @default(now())
  completed Boolean  @default(true)

  // Optional fields
  note      String?

  createdAt DateTime @default(now())

  @@unique([habitId, userId, date])
  @@index([habitId])
  @@index([userId])
  @@index([date])
  @@map("habit_logs")
}

// ============================================
// IDENTITY (Phase 2 - Identity Designer)
// ============================================

model Identity {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String   // "I am a healthy person"
  description String?  // Detailed description

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  habits     Habit[]
  milestones IdentityMilestone[]

  @@index([userId])
  @@map("identities")
}

model IdentityMilestone {
  id         String    @id @default(cuid())
  identityId String
  identity   Identity  @relation(fields: [identityId], references: [id], onDelete: Cascade)

  title      String    // "30 days in a row"
  achieved   Boolean   @default(false)
  achievedAt DateTime?

  createdAt  DateTime  @default(now())

  @@index([identityId])
  @@map("identity_milestones")
}

// ============================================
// WOOP METHOD (Phase 2 - Mental Contrasting)
// ============================================

model WoopPlan {
  id       String @id @default(cuid())
  habitId  String
  habit    Habit  @relation(fields: [habitId], references: [id], onDelete: Cascade)

  wish     String // Wish: What do I want?
  outcome  String // Outcome: Best result?
  obstacle String // Obstacle: What stands in the way?
  plan     String // Plan: If-then for obstacle

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([habitId])
  @@map("woop_plans")
}

// ============================================
// CBT (Phase 3 - Cognitive Behavioral Therapy)
// ============================================

model ThoughtRecord {
  id       String  @id @default(cuid())
  habitId  String?
  habit    Habit?  @relation(fields: [habitId], references: [id], onDelete: SetNull)

  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ABC Model
  adversity    String  // A: What happened
  belief       String  // B: Automatic thought
  consequence  String  // C: Feelings and reactions

  // Cognitive Reframing
  evidence     String? // Evidence FOR and AGAINST
  alternative  String? // Alternative interpretation

  // 3 P's (Learned Optimism)
  permanence      String? // Temporary vs. Permanent
  pervasiveness   String? // Specific vs. Universal
  personalization String? // External vs. Internal

  createdAt DateTime @default(now())

  @@index([habitId])
  @@index([userId])
  @@map("thought_records")
}

// ============================================
// EXTINCTION BURST (Automation Feature)
// ============================================

model ExtinctionBurstEvent {
  id           String    @id @default(cuid())
  habitId      String
  habit        Habit     @relation(fields: [habitId], references: [id], onDelete: Cascade)

  detectedAt   DateTime  @default(now())
  addressedAt  DateTime? // When user completed recovery flow

  previousRate Float     // e.g., 0.85 (85% success rate in previous 14 days)
  recentRate   Float     // e.g., 0.42 (42% success rate in recent 14 days)

  createdAt    DateTime  @default(now())

  @@index([habitId, detectedAt])
  @@index([habitId, addressedAt])
  @@map("extinction_burst_events")
}

// ============================================
// WEEKLY REVIEW (Automation Feature)
// ============================================

model WeeklyReview {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  weekStart     DateTime @db.Date
  weekEnd       DateTime @db.Date

  // Overall insights
  completionRate  Int    // 0-100
  improvement     Int    // -100 to +100
  insights        Json   // WeeklyInsights object

  // Reflection
  reflection      String?

  createdAt     DateTime @default(now())

  // Relations
  difficultyRatings HabitDifficultyLog[]

  @@unique([userId, weekStart])
  @@index([userId, weekStart])
  @@map("weekly_reviews")
}

model HabitDifficultyLog {
  id              String         @id @default(cuid())
  habitId         String
  weeklyReviewId  String?
  weeklyReview    WeeklyReview?  @relation(fields: [weeklyReviewId], references: [id], onDelete: SetNull)

  weekStart       DateTime @db.Date
  rating          Int      // 1-5
  note            String?

  createdAt       DateTime @default(now())

  @@unique([habitId, weekStart])
  @@index([habitId])
  @@index([weeklyReviewId])
  @@map("habit_difficulty_logs")
}

// ============================================
// USER SETTINGS & PREFERENCES
// ============================================

model UserPreferences {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Appearance
  theme     String   @default("system") // "light" | "dark" | "system"
  language  String   @default("cs")     // "cs" | "en"

  // Notifications
  emailNotifications       Boolean @default(true)
  weeklyReviewReminder     Boolean @default(true)
  extinctionBurstAlerts    Boolean @default(true)
  milestoneNotifications   Boolean @default(true)

  // Privacy
  analyticsEnabled         Boolean @default(true)
  dataCollectionConsent    Boolean @default(true)

  // Advanced
  timezone                 String  @default("Europe/Prague")
  dateFormat               String  @default("DD.MM.YYYY")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_preferences")
}

model UserSession {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  token         String   @unique // Session token hash
  ipAddress     String?
  userAgent     String?
  location      String?  // City, Country (from IP geolocation)
  deviceType    String?  // "Desktop" | "Mobile" | "Tablet"
  browser       String?  // "Chrome" | "Firefox" | ...

  lastActiveAt  DateTime @default(now())
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("user_sessions")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  action    String   // "profile.update" | "password.change" | "habit.create" | ...
  resource  String?  // "habit" | "identity" | "user" | ...
  resourceId String? // ID of affected resource

  metadata  Json?    // Additional details (old/new values, etc.)
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action])
  @@map("audit_logs")
}
